    "## Cell 3 — Config (adapted from their configs.json for M4 Mac)"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "import os\n",
    "import torch\n",
    "import glob\n",
    "\n",
    "# ── Find your data directory ──────────────────────────────────────────────\n",
    "# Update this path to where your downloaded .tar files are\n",
    "DATA_ROOT = os.path.expanduser('~/volcano-thesis/data')\n",
    "\n",
    "# Find downloaded shards\n",
    "neg_shards  = sorted(glob.glob(os.path.join(DATA_ROOT, '**/train_neg/*.tar'), recursive=True))\n",
    "pos_shards  = sorted(glob.glob(os.path.join(DATA_ROOT, '**/train_pos/*.tar'), recursive=True))\n",
    "val_shards  = sorted(glob.glob(os.path.join(DATA_ROOT, '**/val/*.tar'),       recursive=True))\n",
    "test_shards = sorted(glob.glob(os.path.join(DATA_ROOT, '**/test/*.tar'),      recursive=True))\n",
    "\n",
    "print('Data found:')\n",
    "print(f'  train_neg shards : {len(neg_shards)}')\n",
    "print(f'  train_pos shards : {len(pos_shards)}')\n",
    "print(f'  val shards       : {len(val_shards)}')\n",
    "print(f'  test shards      : {len(test_shards)}')\n",
    "\n",
    "if not any([neg_shards, pos_shards, val_shards, test_shards]):\n",
    "    print(f'\\n❌ No data found in {DATA_ROOT}')\n",
    "    print('   Update DATA_ROOT above, or download data first')\n",
    "\n",
    "# ── Config matching paper (adapted for M4 Mac) ────────────────────────────\n",
    "CFG = {\n",
    "    # Device — M4 Mac uses MPS\n",
    "    'device'           : str(DEVICE),\n",
    "    'mixed_precision'  : False,   # MPS doesn't support cuda amp\n",
    "\n",
    "    # Data — matches paper exactly\n",
    "    'timeseries_length': 3,       # T = 3 timesteps\n",
    "    'n_geo_channels'   : 3,       # phase, coherence, DEM\n",
    "    'n_atm_channels'   : 0,       # set to 6 to include atmospheric\n",
    "    'image_size'       : 512,\n",
    "    'mask_target'      : 'union',\n",
    "\n",
    "    # Training — matches paper supplementary exactly\n",
    "    'epochs'           : 90,\n",
    "    'lr'               : 1e-5,\n",
    "    'weight_decay'     : 1e-2,    # paper uses 1e-2\n",
    "    'batch_size'       : 2,       # small for M4 16GB\n",
    "    'num_workers'      : 0,       # 0 avoids multiprocessing issues on Mac\n",
    "    'seed'             : 42,\n",
    "    'gradient_clip'    : 1.0,\n",
    "\n",
    "    # Task\n",
    "    'task'             : 'classification',\n",
    "    'num_classes'      : 2,       # paper uses 2-class (Non-Deformation, Deformation)\n",
    "}\n",
    "\n",
    "# Total input channels\n",
    "# Paper flattens: image shape = [T * C, H, W]\n",
    "# Our confirmed: [9, 512, 512] = [3 * 3, 512, 512]\n",
    "CFG['total_channels'] = (CFG['n_geo_channels'] + CFG['n_atm_channels']) * CFG['timeseries_length']\n",
    "print(f'\\nTotal input channels : {CFG[\"total_channels\"]}  (= {CFG[\"timeseries_length\"]} timesteps × {CFG[\"n_geo_channels\"]+CFG[\"n_atm_channels\"]} channels)')\n",
    "print(f'Image input shape    : [{CFG[\"total_channels\"]}, {CFG[\"image_size\"]}, {CFG[\"image_size\"]}]')\n",
    "print(f'Device               : {CFG[\"device\"]}')"
   ],
   "execution_count": null,
   "outputs": []
