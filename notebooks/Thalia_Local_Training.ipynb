    "## Cell 5 — Paper baseline model (ResNet50, matches their code)\n",
    "This is exactly how the paper processes the input — no LSTM."
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "import timm\n",
    "import torch.nn as nn\n",
    "\n",
    "class PaperBaselineModel(nn.Module):\n",
    "    \"\"\"\n",
    "    Exactly replicates the paper's classification model.\n",
    "    \n",
    "    Input  : (B, T*C, H, W) — all timesteps stacked as channels\n",
    "    Output : (B, num_classes)\n",
    "    \n",
    "    This is how the paper does it — no temporal modelling, just a\n",
    "    standard CNN that sees all timesteps simultaneously as extra channels.\n",
    "    \"\"\"\n",
    "    def __init__(self, architecture='resnet50', in_channels=9, num_classes=2):\n",
    "        super().__init__()\n",
    "        self.model = timm.create_model(\n",
    "            architecture,\n",
    "            pretrained    = True,\n",
    "            num_classes   = num_classes,\n",
    "            in_chans      = in_channels  # paper sets this to T*C\n",
    "        )\n",
    "\n",
    "    def forward(self, x):\n",
    "        # x: (B, T*C, H, W) — already flattened time+channels\n",
    "        return self.model(x)  # (B, num_classes)\n",
    "\n",
    "\n",
    "# Build exactly as paper does\n",
    "baseline_model = PaperBaselineModel(\n",
    "    architecture = 'resnet50',\n",
    "    in_channels  = CFG['total_channels'],  # 9\n",
    "    num_classes  = CFG['num_classes']       # 2\n",
    ").to(DEVICE)\n",
    "\n",
    "# Test\n",
    "dummy = torch.randn(2, CFG['total_channels'], 224, 224).to(DEVICE)\n",
    "with torch.no_grad():\n",
    "    out = baseline_model(dummy)\n",
    "\n",
    "params = sum(p.numel() for p in baseline_model.parameters()) / 1e6\n",
    "print('Paper Baseline (ResNet50):')\n",
    "print(f'  Input  : {list(dummy.shape)}  → (B, T*C, H, W)')\n",
    "print(f'  Output : {list(out.shape)}    → (B, num_classes)')\n",
    "print(f'  Params : {params:.1f}M')\n",
    "print(f'  Device : {DEVICE}')\n",
    "print('\\n✅ Baseline model working')"
   ],
   "execution_count": null,
   "outputs": []
