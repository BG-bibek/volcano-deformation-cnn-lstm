   "source": [
    "## Cell 4 — Data loading (using their WebDataset format correctly)"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "import torch\n",
    "import webdataset as wds\n",
    "import io\n",
    "import random\n",
    "import numpy as np\n",
    "from torch.utils.data import DataLoader\n",
    "\n",
    "def decode_thalia_sample(sample):\n",
    "    \"\"\"\n",
    "    Decode one WebDataset sample.\n",
    "    \n",
    "    Returns:\n",
    "        image : Tensor [T*C, H, W] = [9, 512, 512]  (timeseries stacked as channels)\n",
    "        label : int  (0=Non-Deformation, 1=Deformation)\n",
    "        meta  : dict with annotation info\n",
    "    \"\"\"\n",
    "    try:\n",
    "        # Load image tensor — shape [T*C, H, W] = [9, 512, 512]\n",
    "        image = torch.load(\n",
    "            io.BytesIO(sample['image.pth']),\n",
    "            map_location='cpu',\n",
    "            weights_only=False\n",
    "        ).float()\n",
    "\n",
    "        # Load segmentation mask — shape [1, H, W]\n",
    "        mask = torch.load(\n",
    "            io.BytesIO(sample['labels.pth']),\n",
    "            map_location='cpu',\n",
    "            weights_only=False\n",
    "        ).float()\n",
    "\n",
    "        # Load metadata dict\n",
    "        meta = torch.load(\n",
    "            io.BytesIO(sample['sample.pth']),\n",
    "            map_location='cpu',\n",
    "            weights_only=False\n",
    "        )\n",
    "\n",
    "        # Binary label from metadata\n",
    "        binary_label = int(meta['label'][0])\n",
    "\n",
    "        # Per-channel normalisation to [0,1]\n",
    "        for c in range(image.shape[0]):\n",
    "            mn, mx = image[c].min(), image[c].max()\n",
    "            image[c] = (image[c] - mn) / (mx - mn + 1e-8)\n",
    "\n",
    "        # Replace NaN/Inf\n",
    "        image = torch.nan_to_num(image, nan=0.0, posinf=1.0, neginf=0.0)\n",
    "\n",
    "        return image, torch.tensor(binary_label, dtype=torch.long), meta\n",
    "\n",
    "    except Exception as e:\n",
    "        return None\n",
    "\n",
    "\n",
    "def make_loader(shard_list, shuffle=False, batch_size=2):\n",
    "    \"\"\"Build a DataLoader from WebDataset shards.\"\"\"\n",
    "    if not shard_list:\n",
    "        return None\n",
    "\n",
    "    def collate(batch):\n",
    "        batch = [b for b in batch if b is not None]\n",
    "        if not batch:\n",
    "            return None\n",
    "        images = torch.stack([b[0] for b in batch])\n",
    "        labels = torch.stack([b[1] for b in batch])\n",
    "        return images, labels\n",
    "\n",
    "    ds = (\n",
    "        wds.WebDataset(shard_list, shardshuffle=shuffle)\n",
    "        .map(decode_thalia_sample)\n",
    "        .select(lambda x: x is not None)\n",
    "        .batched(batch_size)\n",
    "    )\n",
    "    return DataLoader(ds, batch_size=None,\n",
    "                      num_workers=CFG['num_workers'],\n",
    "                      collate_fn=None)\n",
    "\n",
    "\n",
    "# Build loaders\n",
    "# Paper: train on neg + pos combined, undersampling handled by separate shard dirs\n",
    "train_loader = make_loader(neg_shards + pos_shards, shuffle=True,  batch_size=CFG['batch_size'])\n",
    "val_loader   = make_loader(val_shards,               shuffle=False, batch_size=CFG['batch_size'])\n",
    "test_loader  = make_loader(test_shards,              shuffle=False, batch_size=CFG['batch_size'])\n",
    "\n",
    "# Verify\n",
    "print('Testing data loader...')\n",
    "batch = next(iter(train_loader))\n",
    "images, labels = batch\n",
    "print(f'  Batch images shape : {images.shape}')   # (B, T*C, H, W) = (2, 9, 512, 512)\n",
    "print(f'  Batch labels       : {labels.tolist()}')\n",
    "print(f'  Image value range  : [{images.min():.3f}, {images.max():.3f}]')\n",
    "print()\n",
    "print(f'⚠️  Shape breakdown: {list(images.shape)}')\n",
    "print(f'   = (batch={images.shape[0]},'\n",
    "      f' T*C={images.shape[1]},'\n",
    "      f' H={images.shape[2]},'\n",
    "      f' W={images.shape[3]})')\n",
    "print(f'   = (batch, {CFG[\"timeseries_length\"]} timesteps × {CFG[\"n_geo_channels\"]} channels, 512, 512)')\n",
    "print('\\n✅ DataLoader working')"
   ],
   "execution_count": null,
   "outputs": []
  },
