   "source": [
    "## Cell 7 — Training utilities (matching paper exactly)"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "import torch\n",
    "import torch.nn as nn\n",
    "import numpy as np\n",
    "from sklearn.metrics import f1_score, precision_score, recall_score, roc_auc_score\n",
    "\n",
    "class FocalLoss(nn.Module):\n",
    "    \"\"\"\n",
    "    Focal Loss — paper uses this for ViT and segmentation.\n",
    "    For standard classification (ResNet, ConvNeXt) paper uses CrossEntropy.\n",
    "    \"\"\"\n",
    "    def __init__(self, alpha=0.25, gamma=2.0):\n",
    "        super().__init__()\n",
    "        self.alpha = alpha\n",
    "        self.gamma = gamma\n",
    "\n",
    "    def forward(self, inputs, targets):\n",
    "        ce_loss = nn.functional.cross_entropy(inputs, targets, reduction='none')\n",
    "        pt      = torch.exp(-ce_loss)\n",
    "        loss    = self.alpha * (1 - pt) ** self.gamma * ce_loss\n",
    "        return loss.mean()\n",
    "\n",
    "\n",
    "def compute_metrics(all_labels, all_probs):\n",
    "    \"\"\"\n",
    "    Compute all metrics reported in the paper:\n",
    "    Precision, Recall, F1, AUROC — for the Deformation class.\n",
    "    \"\"\"\n",
    "    all_labels = np.array(all_labels)\n",
    "    all_probs  = np.array(all_probs)  # probability of class 1\n",
    "    all_preds  = (all_probs >= 0.5).astype(int)\n",
    "\n",
    "    if len(np.unique(all_labels)) < 2:\n",
    "        return {'precision': 0, 'recall': 0, 'f1': 0, 'auroc': 50.0}\n",
    "\n",
    "    return {\n",
    "        'precision' : precision_score(all_labels, all_preds, zero_division=0) * 100,\n",
    "        'recall'    : recall_score(all_labels,    all_preds, zero_division=0) * 100,\n",
    "        'f1'        : f1_score(all_labels,        all_preds, zero_division=0) * 100,\n",
    "        'auroc'     : roc_auc_score(all_labels,   all_probs)                  * 100,\n",
    "    }\n",
    "\n",
    "\n",
    "def train_one_epoch(model, loader, optimizer, criterion, device, epoch):\n",
    "    model.train()\n",
    "    total_loss, n_batches = 0.0, 0\n",
    "    n_pos, n_neg = 0, 0\n",
    "\n",
    "    for images, labels in loader:\n",
    "        images = images.to(device)\n",
    "        labels = labels.to(device)\n",
    "\n",
    "        optimizer.zero_grad()\n",
    "        logits = model(images)                    # (B, 2)\n",
    "        loss   = criterion(logits, labels)\n",
    "        loss.backward()\n",
    "\n",
    "        # Gradient clipping (from paper config)\n",
    "        nn.utils.clip_grad_norm_(model.parameters(), CFG['gradient_clip'])\n",
    "        optimizer.step()\n",
    "\n",
    "        total_loss += loss.item()\n",
    "        n_batches  += 1\n",
    "        n_pos      += (labels == 1).sum().item()\n",
    "        n_neg      += (labels == 0).sum().item()\n",
    "\n",
    "        if n_batches % 20 == 0:\n",
    "            print(f'  Epoch {epoch} | Batch {n_batches:4d} | loss: {loss.item():.4f}')\n",
    "\n",
    "    print(f'  Epoch {epoch} | pos: {n_pos} | neg: {n_neg} | loss: {total_loss/n_batches:.4f}')\n",
    "    return total_loss / n_batches\n",
    "\n",
    "\n",
    "@torch.no_grad()\n",
    "def evaluate(model, loader, criterion, device):\n",
    "    model.eval()\n",
    "    total_loss, n_batches = 0.0, 0\n",
    "    all_labels, all_probs = [], []\n",
    "\n",
    "    for images, labels in loader:\n",
    "        images = images.to(device)\n",
    "        labels = labels.to(device)\n",
    "\n",
    "        logits = model(images)                     # (B, 2)\n",
    "        loss   = criterion(logits, labels)\n",
    "\n",
    "        probs  = torch.softmax(logits, dim=1)[:, 1]  # prob of class 1\n",
    "        all_probs.extend(probs.cpu().numpy().tolist())\n",
    "        all_labels.extend(labels.cpu().numpy().tolist())\n",
    "\n",
    "        total_loss += loss.item()\n",
    "        n_batches  += 1\n",
    "\n",
    "    metrics        = compute_metrics(all_labels, all_probs)\n",
    "    metrics['loss'] = total_loss / max(n_batches, 1)\n",
    "    return metrics\n",
    "\n",
    "\n",
    "print('✅ Training utilities ready')\n",
    "print('   Using CrossEntropyLoss (paper uses this for ResNet/ConvNeXt)')"
   ],
   "execution_count": null,
   "outputs": []
  },
