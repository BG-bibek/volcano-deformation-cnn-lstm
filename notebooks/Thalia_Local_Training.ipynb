   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 6 — YOUR LSTM model (thesis contribution)\n",
    "Key difference: processes each timestep separately through CNN, then LSTM models the sequence."
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "import timm\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "\n",
    "class CNNLSTMClassifier(nn.Module):\n",
    "    \"\"\"\n",
    "    CNN + LSTM for InSAR time-series classification.\n",
    "    Your thesis contribution vs the paper's flat CNN approach.\n",
    "\n",
    "    KEY DIFFERENCE from paper:\n",
    "    - Paper  : (B, T*C, H, W) → CNN → classify  (all timesteps at once)\n",
    "    - Yours  : (B, T*C, H, W) → reshape → per-frame CNN → LSTM → classify\n",
    "\n",
    "    The input shape is the SAME as the paper's (B, T*C, H, W).\n",
    "    We reshape it internally to (B, T, C, H, W) for sequential processing.\n",
    "\n",
    "    Args:\n",
    "        backbone      : CNN backbone name (timm model)\n",
    "        in_channels   : channels per timestep (3 for geo only, 9 for geo+atm)\n",
    "        timeseries_len: number of timesteps T\n",
    "        lstm_hidden   : LSTM hidden state size\n",
    "        lstm_layers   : number of stacked LSTM layers\n",
    "        bidirectional : use BiLSTM?\n",
    "        num_classes   : output classes (2 for binary)\n",
    "        dropout       : dropout rate\n",
    "    \"\"\"\n",
    "    def __init__(\n",
    "        self,\n",
    "        backbone       = 'resnet50',\n",
    "        in_channels    = 3,\n",
    "        timeseries_len = 3,\n",
    "        lstm_hidden    = 256,\n",
    "        lstm_layers    = 1,\n",
    "        bidirectional  = False,\n",
    "        num_classes    = 2,\n",
    "        dropout        = 0.3,\n",
    "        pretrained     = True\n",
    "    ):\n",
    "        super().__init__()\n",
    "        self.T          = timeseries_len\n",
    "        self.C          = in_channels\n",
    "        self.num_classes = num_classes\n",
    "\n",
    "        # ── 1. CNN backbone (processes one timestep at a time) ─────────\n",
    "        self.cnn = timm.create_model(\n",
    "            backbone,\n",
    "            pretrained  = pretrained,\n",
    "            num_classes = 0,         # remove classification head\n",
    "            global_pool = 'avg',     # output: (B, cnn_features)\n",
    "            in_chans    = in_channels\n",
    "        )\n",
    "        cnn_out = self.cnn.num_features  # 2048 for ResNet50\n",
    "\n",
    "        # ── 2. LSTM temporal encoder ────────────────────────────────────\n",
    "        self.lstm = nn.LSTM(\n",
    "            input_size    = cnn_out,\n",
    "            hidden_size   = lstm_hidden,\n",
    "            num_layers    = lstm_layers,\n",
    "            batch_first   = True,\n",
    "            bidirectional = bidirectional,\n",
    "            dropout       = dropout if lstm_layers > 1 else 0.0\n",
    "        )\n",
    "        lstm_out = lstm_hidden * (2 if bidirectional else 1)\n",
    "\n",
    "        # ── 3. Classification head ──────────────────────────────────────\n",
    "        self.head = nn.Sequential(\n",
    "            nn.LayerNorm(lstm_out),\n",
    "            nn.Dropout(dropout),\n",
    "            nn.Linear(lstm_out, 128),\n",
    "            nn.GELU(),\n",
    "            nn.Dropout(dropout / 2),\n",
    "            nn.Linear(128, num_classes)\n",
    "        )\n",
    "\n",
    "    def forward(self, x):\n",
    "        \"\"\"\n",
    "        Args:\n",
    "            x: (B, T*C, H, W) — same input format as paper\n",
    "        Returns:\n",
    "            logits: (B, num_classes)\n",
    "        \"\"\"\n",
    "        B, TC, H, W = x.shape\n",
    "        T, C = self.T, self.C\n",
    "        assert TC == T * C, f'Expected {T}×{C}={T*C} channels, got {TC}'\n",
    "\n",
    "        # Step 1: Reshape to separate time from channels\n",
    "        # (B, T*C, H, W) → (B, T, C, H, W)\n",
    "        x = x.view(B, T, C, H, W)\n",
    "\n",
    "        # Step 2: Process each timestep through CNN in parallel\n",
    "        # (B, T, C, H, W) → (B*T, C, H, W) → CNN → (B*T, cnn_features)\n",
    "        x_flat = x.view(B * T, C, H, W)\n",
    "        feats  = self.cnn(x_flat)        # (B*T, cnn_features)\n",
    "        feats  = feats.view(B, T, -1)    # (B, T, cnn_features)\n",
    "\n",
    "        # Step 3: LSTM over the time dimension\n",
    "        lstm_out, _ = self.lstm(feats)   # (B, T, lstm_hidden)\n",
    "\n",
    "        # Step 4: Use final timestep hidden state for classification\n",
    "        last = lstm_out[:, -1, :]        # (B, lstm_hidden)\n",
    "\n",
    "        return self.head(last)            # (B, num_classes)\n",
    "\n",
    "\n",
    "# Build LSTM model\n",
    "lstm_model = CNNLSTMClassifier(\n",
    "    backbone       = 'resnet50',\n",
    "    in_channels    = CFG['n_geo_channels'],     # 3 channels per timestep\n",
    "    timeseries_len = CFG['timeseries_length'],   # T=3\n",
    "    lstm_hidden    = 256,\n",
    "    lstm_layers    = 1,\n",
    "    bidirectional  = False,\n",
    "    num_classes    = CFG['num_classes'],          # 2\n",
    "    dropout        = 0.3,\n",
    "    pretrained     = True\n",
    ").to(DEVICE)\n",
    "\n",
    "# Test with same shape as paper's model\n",
    "dummy = torch.randn(2, CFG['total_channels'], 224, 224).to(DEVICE)\n",
    "with torch.no_grad():\n",
    "    out = lstm_model(dummy)\n",
    "\n",
    "params = sum(p.numel() for p in lstm_model.parameters()) / 1e6\n",
    "print('CNN-LSTM Model (your contribution):')\n",
    "print(f'  Input  : {list(dummy.shape)}  → (B, T*C, H, W)')\n",
    "print(f'  Internally reshapes to (B=2, T=3, C=3, H, W)')\n",
    "print(f'  Output : {list(out.shape)}    → (B, num_classes)')\n",
    "print(f'  Params : {params:.1f}M')\n",
    "print(f'  Device : {DEVICE}')\n",
    "print()\n",
    "print('Paper CNN (ResNet50): sees all timesteps at once as 9 channels')\n",
    "print('Your CNN-LSTM       : processes each timestep separately, LSTM models the sequence')\n",
    "print('\\n✅ CNN-LSTM model working')"
   ],
   "execution_count": null,
   "outputs": []
  },
